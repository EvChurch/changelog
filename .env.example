# Database (PostgreSQL). Railway provides DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Planning Center Online
# OAuth app (sign-in only: identifies who the user is; no user token used for API calls)
PCO_CLIENT_ID=""
PCO_CLIENT_SECRET=""
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/pco

# API key for all PCO API calls (teams, leaders, people). Required. OAuth is identity only.
# PCO_API_KEY=""

# PCO Services – service type ID for teams/leaders (required for sync and teams list)
# PCO_SERVICE_TYPE_ID=""
