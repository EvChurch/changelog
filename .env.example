# Database (PostgreSQL). Railway provides DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Planning Center Online OAuth
PCO_CLIENT_ID=""
PCO_CLIENT_SECRET=""
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/pco

# Optional: PCO Services API – service type ID for fetching teams
# PCO_SERVICE_TYPE_ID=""
