# Database (PostgreSQL). Railway provides DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Planning Center Online
# OAuth app (sign-in only: identifies who the user is; no user token used for API calls)
PCO_CLIENT_ID=""
PCO_CLIENT_SECRET=""
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/pco

# API credentials for all PCO API calls (teams, leaders, people). HTTP Basic Auth. Required. OAuth is identity only.
PCO_API_ID=""
PCO_API_SECRET=""
