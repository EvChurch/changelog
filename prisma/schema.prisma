// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FeedbackStatus {
  pending_driver_review
  pending_leader_review
  accepted
}

enum FeedbackSource {
  driver
  member
}

model User {
  id           String        @id @default(cuid())
  pcoId        String        @unique
  email        String?
  name         String?
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  drivers      Driver[]
  leaders      Leader[]
  teamMembers  TeamMember[]
  feedback     Feedback[]    @relation("CreatedBy")
}

model ServiceType {
  id             String   @id @default(cuid())
  pcoServiceTypeId String @unique
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teams          Team[]
}

model Team {
  id             String       @id @default(cuid())
  pcoTeamId      String       @unique
  serviceTypeId  String?
  name           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  serviceType    ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  leaders        Leader[]
  members        TeamMember[]
  feedback       Feedback[]
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@unique([userId, teamId])
}

model Driver {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leader {
  id     String @id @default(cuid())
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@unique([userId, teamId])
}

model Feedback {
  id                  String         @id @default(cuid())
  teamId              String
  createdById         String
  content             String
  status              FeedbackStatus
  source              FeedbackSource
  leaderComment       String?
  acceptedAt         DateTime?
  driverComment      String?
  reviewedByDriverAt  DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  team                Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy           User           @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}
