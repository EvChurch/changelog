// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FeedbackStatus {
  pending_driver_review
  pending_leader_review
  accepted
}

enum FeedbackSource {
  driver
  member
}

enum ObjectiveStatus {
  not_started
  in_progress
  completed
  on_hold
}

enum Provider {
  pco
  rock
}

model Person {
  id          String       @id @default(cuid())
  remoteId    String
  provider    Provider
  email       String?
  fullName    String
  firstName   String
  lastName    String
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  drivers     Driver[]
  leaders     Leader[]
  assignments Assignment[]
  feedback    Feedback[]   @relation("CreatedBy")
  objectivesCreated  Objective[] @relation("ObjectiveCreatedBy")
  objectivesAssigned Objective[] @relation("ObjectiveAssignee")

  @@unique([remoteId, provider])
}

model ServiceType {
  id        String   @id @default(cuid())
  remoteId  String
  provider  Provider
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teams     Team[]
  drivers   Driver[]

  @@unique([remoteId, provider])
}

model Team {
  id            String       @id @default(cuid())
  remoteId      String
  provider      Provider
  serviceTypeId String?
  name          String
  descriptionMarkdown String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  leaders       Leader[]
  positions     Position[]
  feedback      Feedback[]

  @@unique([remoteId, provider])
}

model Position {
  id          String       @id @default(cuid())
  remoteId    String
  provider    Provider
  teamId      String
  name        String?
  descriptionMarkdown String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  objectives  Objective[]

  @@unique([remoteId, provider])
}

model Assignment {
  id         String   @id @default(cuid())
  remoteId   String
  provider   Provider
  personId   String
  positionId String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([personId, positionId])
  @@unique([remoteId, provider])
}

model Driver {
  personId      String
  serviceTypeId String
  person        Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@unique([personId, serviceTypeId])
}

model Leader {
  id       String   @id @default(cuid())
  remoteId String
  provider Provider
  personId String
  teamId   String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([personId, teamId])
  @@unique([remoteId, provider])
}

model Feedback {
  id                 String         @id @default(cuid())
  teamId             String
  personId           String
  content            String
  status             FeedbackStatus
  source             FeedbackSource
  leaderComment      String?
  acceptedAt         DateTime?
  driverComment      String?
  reviewedByDriverAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  team               Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy          Person         @relation("CreatedBy", fields: [personId], references: [id], onDelete: Cascade)
}

model Objective {
  id                 String          @id @default(cuid())
  positionId         String
  createdByPersonId  String
  assigneePersonId   String?
  title              String
  descriptionMarkdown String?
  status             ObjectiveStatus @default(not_started)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  position           Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdBy          Person          @relation("ObjectiveCreatedBy", fields: [createdByPersonId], references: [id], onDelete: Cascade)
  assignee           Person?         @relation("ObjectiveAssignee", fields: [assigneePersonId], references: [id], onDelete: SetNull)
  keyResults         KeyResult[]

  @@index([positionId])
  @@index([assigneePersonId])
}

model KeyResult {
  id                 String    @id @default(cuid())
  objectiveId        String
  title              String
  descriptionMarkdown String?
  progress           Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  objective          Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
}
