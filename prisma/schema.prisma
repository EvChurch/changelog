// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FeedbackStatus {
  pending_driver_review
  pending_leader_review
  accepted
}

enum FeedbackSource {
  driver
  member
}

model Person {
  id          String       @id
  email       String?
  fullName    String
  firstName   String
  lastName    String
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  driver      Driver?
  leaders     Leader[]
  assignments Assignment[]
  feedback    Feedback[]   @relation("CreatedBy")
}

model ServiceType {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teams     Team[]
}

model Team {
  id            String       @id
  serviceTypeId String?
  name          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  leaders       Leader[]
  positions     Position[]
  feedback      Feedback[]
}

model Position {
  id          String       @id
  teamId      String
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments Assignment[]
}

model Assignment {
  personId     String
  positionId   String
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  teamPosition Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([personId, positionId])
}

model Driver {
  id     String @id
  person Person @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Leader {
  personId String
  teamId   String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([personId, teamId])
}

model Feedback {
  id                 String         @id @default(cuid())
  teamId             String
  personId           String
  content            String
  status             FeedbackStatus
  source             FeedbackSource
  leaderComment      String?
  acceptedAt         DateTime?
  driverComment      String?
  reviewedByDriverAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  team               Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy          Person         @relation("CreatedBy", fields: [personId], references: [id], onDelete: Cascade)
}
